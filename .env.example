# ============================================================================
# chunklab environment — copy to .env and fill in. NEVER commit the real .env.
# ============================================================================

# ---- LLM (Groq) ----
# Get a free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embeddings (local, free) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---- Database (Postgres + pgvector) ----
# Inside docker compose the host is `postgres`; for local runs use `localhost`.
DATABASE_URL=postgresql+asyncpg://chunklab:chunklab@postgres:5432/chunklab
POSTGRES_USER=chunklab
POSTGRES_PASSWORD=chunklab
POSTGRES_DB=chunklab

# ---- Redis (jobs + progress) ----
REDIS_URL=redis://redis:6379/0

# ---- Retrieval / evaluation ----
TOP_K=5
QA_PAIRS_PER_FILE=8

# ---- Cost model (notional, configurable) ----
# Embedding cost is notional (local model has no API cost) so combinations are
# dollar-comparable. Groq judge cost is computed from real response.usage.
EMBED_COST_PER_1K=0.00002
GROQ_INPUT_COST_PER_M=0.59
GROQ_OUTPUT_COST_PER_M=0.79

# ---- API / CORS ----
CORS_ORIGINS=http://localhost:3000
