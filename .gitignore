# ===== SECRETS — never commit =====
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ===== Node / Next.js =====
node_modules/
.next/
out/
frontend/.next/
frontend/node_modules/
frontend/out/
*.tsbuildinfo
next-env.d.ts

# ===== Data / runtime =====
*.db
*.sqlite3

# ----- User-uploaded files are NEVER committed -----
backend/app/data/        # local STORAGE_DIR (backend/app/data/uploads)
uploads/
storage/
# (sample_docs/ IS tracked on purpose — those are demo inputs, not user uploads)
!sample_docs/

